# Space IM Docker environment
#
# Quick start:
#   cp .env.example .env
#   edit SPACE_ADMIN_PASSWORD, SPACE_ADMIN_SESSION_SECRET, MINIO_EXTERNAL_ADDRESS
#   docker compose up -d --build

# Required application settings
OPENIM_SECRET=openIM123
SPACE_ADMIN_PHONE_NUMBER=18888888888
SPACE_ADMIN_PASSWORD=password123
SPACE_ADMIN_SESSION_SECRET=change-me
MINIO_EXTERNAL_ADDRESS=http://your-domain-or-ip:10005
APP_UPDATE_STORAGE_DIR=/app/storage

# Local images built by docker compose
SPACE_CHAT_SERVER_IMAGE=space-im-chat-server:latest
SPACE_ADMIN_IMAGE=space-im-admin:latest

# Third-party images
MONGO_IMAGE=mongo:7.0
REDIS_IMAGE=redis:7.0.0
ETCD_IMAGE=bitnamilegacy/etcd:3.5.13
KAFKA_IMAGE=bitnamilegacy/kafka:3.5.1
MINIO_IMAGE=minio/minio:RELEASE.2024-01-11T07-46-16Z
OPENIM_SERVER_IMAGE=openim/openim-server:v3.8.3-patch.12

# Data directory
DATA_DIR=./

# MongoDB for OpenIM
MONGO_ADDRESS=mongo:27017
MONGO_USERNAME=openIM
MONGO_PASSWORD=openIM123

# MongoDB for Space IM chat-server
SPACE_CHAT_MONGODB_DATABASE=chat_server
SPACE_CHAT_MONGO_USERNAME=chatService
SPACE_CHAT_MONGO_PASSWORD=chatService123
SPACE_CHAT_MONGO_AUTH_SOURCE=chat_server

# Redis
REDIS_ADDRESS=redis:6379
REDIS_PASSWORD=openIM123

# Etcd
ETCD_ADDRESS=etcd:2379

# Kafka
KAFKA_ADDRESS=kafka:9094

# MinIO
MINIO_INTERNAL_ADDRESS=minio:9000
MINIO_ACCESS_KEY_ID=root
MINIO_SECRET_ACCESS_KEY=openIM123

# OpenIM
SPACE_CHAT_OPENIM_API_URL=http://openim-server:10002
SPACE_CHAT_OPENIM_ADMIN_USER_ID=imAdmin
SPACE_CHAT_OPENIM_MESSAGE_SEARCH_PATH=/msg/search_msg
LOG_IS_STDOUT=true
LOG_LEVEL=3
GRAFANA_URL=http://external_ip:13000/

# Host ports
OPENIM_API_PORT=10002
OPENIM_MSG_GATEWAY_PORT=10001
MINIO_PORT=10005
SPACE_CHAT_SERVER_PORT=3000
SPACE_ADMIN_PORT=18080

# Optional service authentication. Leave empty unless you enable auth for Etcd/Kafka.
ETCD_ROOT_USER=
ETCD_ROOT_PASSWORD=
ETCD_USERNAME=
ETCD_PASSWORD=
KAFKA_USERNAME=
KAFKA_PASSWORD=
